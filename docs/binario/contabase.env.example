# ContaBase - exemplo de /etc/contabase/contabase.env
#
# Copie para /etc/contabase/contabase.env, ajuste para o seu ambiente e mantenha o
# arquivo com owner root:root e permissao 600.

APP_ENV=production
APP_DEBUG=false
PORT=8080

DATABASE_URL=file:/var/lib/contabase/contabase.db
DATA_DIR=/var/lib/contabase
DB_FILE=/var/lib/contabase/contabase.db
UPLOADS_DIR=/var/lib/contabase/uploads

APP_BASE_URL=https://fin.seu-dominio.com
ALLOWED_HOSTS=fin.seu-dominio.com
TRUSTED_PROXIES=127.0.0.1/32

# Gere e substitua estes valores antes do primeiro uso:
CONTABASE_SETUP_TOKEN=__PREENCHA_APENAS_NO_SETUP_INICIAL__
AUTH_ENCRYPTION_KEY=__GERAR_COM_OPENSSL_RAND_BASE64_32__
SECURITY_MASTER_KEY=__GERAR_COM_OPENSSL_RAND_HEX_16__
